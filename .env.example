# ============================================================
# 損保アプリ 本番環境変数テンプレート（現行プロジェクト対応）
# ============================================================
# 使い方:
#   1. このファイルをコピーして .env を作成
#      cp .env.example .env
#   2. 「ここに〜」の値を実際の秘密情報に置き換える
#   3. docker compose up -d --build で起動
#
# 注意:
# - このプロジェクトは docker-compose.yaml で DB_URL/DB_USERNAME/DB_PASSWORD を参照します
# - Lightsail 等でコンテナ間接続する場合は DB_URL のホストを mysql にします
# ============================================================

# --- MySQL コンテナ初期化用 ---
MYSQL_ROOT_PASSWORD=ここに強力なルートパスワードを設定
MYSQL_DATABASE=insuranceapp
MYSQL_USER=insurance_user
MYSQL_PASSWORD=ここにアプリ用DBパスワードを設定
MYSQL_HOST_PORT=3307

# --- Spring Profile ---
SPRING_PROFILES_ACTIVE=production

# --- Spring Boot データソース（application-production.yaml が参照） ---
DB_URL=jdbc:mysql://mysql:3306/insuranceapp?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Tokyo
DB_USERNAME=insurance_user
DB_PASSWORD=ここにアプリ用DBパスワードを設定（MYSQL_PASSWORDと同じ推奨）

# --- Google OAuth 2.0（Googleカレンダー連携） ---
GOOGLE_CLIENT_ID=ここにGoogle CloudのクライアントID
GOOGLE_CLIENT_SECRET=ここにGoogle Cloudのクライアントシークレット

# --- Gemini API ---
AI_DAILY_USAGE_LIMIT=20
GEMINI_API_KEY=ここにGemini APIキー
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_MODEL=gemini-1.5-flash
